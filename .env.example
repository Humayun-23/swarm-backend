
APP_NAME="Event Logistics Swarm"
APP_VERSION="1.0.0"
DEBUG=True
ENVIRONMENT=development


HOST=0.0.0.0
PORT=8000


DATABASE_URL=postgresql+asyncpg://DB_USER:DB_PASSWORD@localhost:5432/event_logistics
DATABASE_ECHO=False


REDIS_URL=redis://localhost:6379/0


SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30


OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000


VECTOR_STORE_TYPE=chroma
CHROMA_PERSIST_DIRECTORY=./chroma_db
PGVECTOR_ENABLED=False



SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=[your-email@gmail.com](mailto:your-email@gmail.com)
SMTP_PASSWORD=your-email-app-password
SMTP_FROM_EMAIL=[noreply@eventlogistics.com](mailto:noreply@eventlogistics.com)
SMTP_FROM_NAME="Event Logistics Swarm"



CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0



CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]



LOG_LEVEL=INFO
LOG_FILE=logs/app.log
